<Window x:Class="Update.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Update"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" Loaded="Window_Loaded" >
    <Grid>
        <StackPanel>
            <TextBlock Text="old文件路径"/>
            <TextBox x:Name="SoftWarePath"/>


            <TextBlock Text="所有IP"/>
            <TextBox x:Name="allAddress" TextWrapping="Wrap" Height="200" />

            <StackPanel Orientation="Horizontal">
                <Button Content="保存" Click="Button_Click" Width="100" Height="50" Margin="5"/>
                <Button Content="更新" Click="Button2_Click" Width="100" Height="50" Margin="5"/>
                <CheckBox x:Name="IsSimulate" >模拟mes</CheckBox>
            </StackPanel>
           
        </StackPanel>
        
    </Grid>
</Window>
