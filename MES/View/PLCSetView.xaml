<UserControl x:Class="MES.PLCSetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MES"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:vm="clr-namespace:MES.ViewModel"
             d:DesignHeight="450"
             d:DesignWidth="800"
             Background="White"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <vm:PLCSetViewModel />
    </UserControl.DataContext>
    <Border Margin="2"
            BorderBrush="Black"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>

            <StackPanel Margin="5"
                        DataContext="{Binding PLCSetting}"
                        Orientation="Horizontal">
                <TextBlock Text="IP地址"
                           Grid.Column="0"
                           Margin="5,0"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                <TextBox Text="{Binding IPAddress}"
                         Grid.Column="1"
                         Width="140"
                         Margin="5,0"
                         Padding="2"
                         FontSize="18" />
                <TextBlock Text="端口"
                           Visibility="Collapsed"
                           Grid.Column="2"
                           Margin="5,0"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                <TextBox Text="{Binding Port}"
                         Visibility="Collapsed"
                         Grid.Column="3"
                         Width="50"
                         Height="30"
                         Margin="5,0"
                         Padding="2"
                         FontSize="18" />

                <TextBlock Text="读取DB"
                           Grid.Column="2"
                           Margin="5,0"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                <TextBox Text="{Binding ReadDB}"
                         Grid.Column="3"
                         Width="60"
                         Height="30"
                         Margin="5,0"
                         Padding="2"
                         FontSize="18" />

                <TextBlock Text="写入DB"
                           Grid.Column="2"
                           Margin="5,0"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                <TextBox Text="{Binding WriteDB}"
                         Grid.Column="3"
                         Width="60"
                         Height="30"
                         Margin="5,0"
                         Padding="2"
                         FontSize="18" />

            </StackPanel>

            <ComboBox Height="30"
                      Width="100"
                      Margin="10,0"
                      HorizontalAlignment="Center"
                      HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center"
                      DisplayMemberPath="ProductName"
                      ItemsSource="{Binding productTypes}"
                      SelectedItem="{Binding ProductType}"
                      SelectedValuePath="ProductID">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="SelectionChanged">
                        <i:InvokeCommandAction Command="{Binding ProductTypeChange}"
                                               CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>

            </ComboBox>


            <StackPanel HorizontalAlignment="Right"
                        Orientation="Horizontal">

                <Border Margin="2"
                        BorderBrush="Black"
                        BorderThickness="0.5">
                    <StackPanel  Orientation="Horizontal"
                                 Margin="2">
                        <TextBlock Text="序号从"
                                   Width="40"
                                   Height="20" />

                        <ComboBox ItemsSource="{Binding NumberIndex}"
                                  SelectedItem="{Binding CopyFromNumber}"
                                  SelectedIndex="0"
                                  Height="30"
                                  HorizontalContentAlignment="Center"
                                  VerticalContentAlignment="Center"
                                  Width="55" />

                        <TextBlock Text="到"
                                   Width="15"
                                   Margin="2,0"
                                   Height="20" />

                        <ComboBox ItemsSource="{Binding NumberIndex}"
                                  SelectedItem="{Binding CopyToNumber}"
                                  SelectedIndex="0"
                                  Height="30"
                                  HorizontalContentAlignment="Center"
                                  VerticalContentAlignment="Center"
                                  Width="55" />
                        <Button Width="55"
                                Height="30"
                                Margin="5,0"
                                Command="{Binding DataContext.CopyDbCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"
                                Content="复制DB" />
                    </StackPanel>
                </Border>
                <Button Width="55"
                        Height="30"
                        Margin="5"
                        Command="{Binding DataContext.ToJsonCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"
                        Content="导出Json"
                        Visibility="Collapsed" />
                <Button Width="50"
                        Height="30"
                        Margin="5"
                        Command="{Binding DataContext.EditDBCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"
                        Content="修改DB" />
                <ComboBox ItemsSource="{Binding DbIndex}"
                          HorizontalContentAlignment="Center"
                          Height="30"
                          VerticalContentAlignment="Center"
                          SelectedItem="{Binding SelectDbItem}"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center" />
                <Button Width="50"
                        Height="30"
                        Margin="5"
                        Command="{Binding DataContext.ExportCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"
                        Content="导出cs"
                        Visibility="Collapsed" />

                <Button Width="50"
                        Height="30"
                        Margin="5"
                        Command="{Binding DataContext.SaveCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"
                        Content="保存" />
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="2"
                    BorderBrush="Black"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>
                    <Grid DataContext="{Binding EditPLCGroup}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding GroupName}"
                                 Grid.Column="0"
                                 Margin="2"
                                 Padding="5"
                                 FontSize="18" />
                        <ComboBox Text="{Binding GroupType}"
                                  Grid.Column="1"
                                  Margin="2"
                                  Padding="5"
                                  FontSize="18">
                            <sys:String>TriggerGroup</sys:String>
                            <sys:String>WriteGroup</sys:String>
                            <sys:String>ReadGroup</sys:String>
                            <sys:String>CheckOutGroup</sys:String>
                            <sys:String>OeeGroup</sys:String>
                            <sys:String>GetParaGroup</sys:String>
                            <sys:String>AlarmGroup</sys:String>
                            <sys:String>FormulaGroup</sys:String>
                            <sys:String>DataCollectionGroup</sys:String>
                        </ComboBox>
                        <TextBox Text="{Binding RefreshTime}"
                                 Grid.Column="2"
                                 Margin="2"
                                 Padding="5"
                                 FontSize="18" />
                        <TextBox Text="{Binding GroupDesc}"
                                 Grid.Column="3"
                                 Margin="2"
                                 Padding="5"
                                 FontSize="18" />
                    </Grid>
                    <Grid Grid.Row="1">
                        <DataGrid Margin="2"
                                  AutoGenerateColumns="False"
                                  BorderThickness="0.1"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  GridLinesVisibility="All"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding PLCSetting.ListGroup}"
                                  SelectedIndex="0"
                                  SelectedValue="{Binding SelectPLCGroup}">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="SelectedCellsChanged">
                                    <i:InvokeCommandAction Command="{Binding SelectionChange}" />
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="组名"
                                                    Width="*"
                                                    Binding="{Binding GroupName}"
                                                    FontSize="13" />
                                <DataGridTextColumn Header="组类型"
                                                    Width="*"
                                                    Binding="{Binding GroupType}"
                                                    FontSize="13" />
                                <DataGridTextColumn Header="刷新速率"
                                                    Width="*"
                                                    Binding="{Binding RefreshTime}"
                                                    FontSize="13" />
                                <DataGridTextColumn Header="备注"
                                                    Width="*"
                                                    Binding="{Binding GroupDesc}"
                                                    FontSize="13" />
                            </DataGrid.Columns>
                        </DataGrid>

                    </Grid>
                    <Grid Grid.RowSpan="2"
                          Grid.Column="1">
                        <StackPanel VerticalAlignment="Center">
                            <Button Height="30"
                                    Margin="5"
                                    Command="{Binding AddGroupCommand}"
                                    CommandParameter="{Binding EditPLCGroup}"
                                    Content="增加" />
                            <Button Height="30"
                                    Margin="5"
                                    Command="{Binding EditGroupCommand}"
                                    CommandParameter="{Binding EditPLCGroup}"
                                    Content="修改" />
                            <Button Height="30"
                                    Margin="5"
                                    Command="{Binding DeleteGroupCommand}"
                                    CommandParameter="{Binding EditPLCGroup}"
                                    Content="删除" />
                        </StackPanel>

                    </Grid>
                </Grid>
            </Border>
            <Border Grid.Row="2"
                    Margin="2"
                    BorderBrush="Black"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>
                    <Grid DataContext="{Binding EditPLCTag}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <TextBox Text="{Binding TagName}"
                                 Grid.Column="0"
                                 Margin="2"
                                 Padding="5"
                                 FontSize="18">
                        </TextBox>
                        <TextBox Text="{Binding TagDbArea}"
                                 Grid.Column="1"
                                 Margin="2"
                                 Padding="5"
                                 FontSize="18">
                        </TextBox>
                        <TextBox Text="{Binding TagAddress}"
                                 Grid.Column="2"
                                 Margin="2"
                                 Padding="5"
                                 FontSize="18">
                        </TextBox>
                        <ComboBox Text="{Binding DataType}"
                                  Grid.Column="3"
                                  Margin="2"
                                  Padding="5,6"
                                  FontSize="18">
                            <sys:String>int</sys:String>
                            <sys:String>intArray</sys:String>
                            <sys:String>real</sys:String>
                            <sys:String>bool</sys:String>
                            <sys:String>boolArray</sys:String>
                            <sys:String>string</sys:String>
                        </ComboBox>
                        <TextBox Text="{Binding TagDesc}"
                                 Grid.Column="4"
                                 Margin="2"
                                 Padding="5"
                                 FontSize="18">
                        </TextBox>
                        <TextBox Text="{Binding TagValue}"
                                 Grid.Column="5"
                                 Margin="2"
                                 Padding="5"
                                 FontSize="18">
                        </TextBox>
                        <TextBox Text="{Binding UpLimit}"
                                 Grid.Column="6"
                                 Margin="2"
                                 Padding="5"
                                 FontSize="18">
                        </TextBox>
                        <TextBox Text="{Binding LowLimit}"
                                 Grid.Column="7"
                                 Margin="2"
                                 Padding="5"
                                 FontSize="18">
                        </TextBox>
                    </Grid>
                    <DataGrid Grid.Row="1"
                              Margin="2"
                              AutoGenerateColumns="False"
                              BorderThickness="1"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              DataContext="{Binding SelectPLCGroup}"
                              GridLinesVisibility="All"
                              IsReadOnly="True"
                              ItemsSource="{Binding ListTag, Mode=TwoWay}"
                              SelectedValue="{Binding DataContext.SelectPLCTag, RelativeSource={RelativeSource AncestorType=UserControl, Mode=FindAncestor}}"
                              SelectionMode="Extended">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectedCellsChanged">
                                <i:InvokeCommandAction Command="{Binding DataContext.TagSelectionChange, RelativeSource={RelativeSource AncestorType=UserControl, Mode=FindAncestor}}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="标签名"
                                                Width="*"
                                                Binding="{Binding TagName}"
                                                FontSize="13" />
                            <DataGridTextColumn Header="数据区域"
                                                Width="*"
                                                Binding="{Binding TagDbArea}"
                                                FontSize="13" />
                            <DataGridTextColumn Header="标签地址"
                                                Width="*"
                                                Binding="{Binding TagAddress}"
                                                FontSize="13" />
                            <DataGridTextColumn Header="数据类型"
                                                Width="*"
                                                Binding="{Binding DataType}"
                                                FontSize="13" />
                            <DataGridTextColumn Header="描述"
                                                Width="*"
                                                Binding="{Binding TagDesc}"
                                                FontSize="13" />
                            <DataGridTextColumn Header="参数值"
                                                Width="*"
                                                Binding="{Binding TagValue}"
                                                FontSize="13" />
                            <DataGridTextColumn Header="参数上限"
                                                Width="*"
                                                Binding="{Binding UpLimit}"
                                                FontSize="13" />
                            <DataGridTextColumn Header="参数下限"
                                                Width="*"
                                                Binding="{Binding LowLimit}"
                                                FontSize="13" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Grid Grid.RowSpan="2"
                          Grid.Column="1">
                        <StackPanel VerticalAlignment="Center">
                            <!--添加到所有型号-->
                            <CheckBox Height="30"
                                      Margin="5"
                                      IsChecked="{Binding isAll}"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center" />

                            <Button Height="30"
                                    Margin="5"
                                    Command="{Binding AddTagCommand}"
                                    CommandParameter="{Binding EditPLCTag}"
                                    Content="增加" />
                            <Button Height="30"
                                    Margin="5"
                                    Command="{Binding EditTagCommand}"
                                    CommandParameter="{Binding EditPLCTag}"
                                    Content="修改" />
                            <Button Height="30"
                                    Margin="5"
                                    Command="{Binding DeleteTagCommand}"
                                    CommandParameter="{Binding EditPLCTag}"
                                    Content="删除" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

        </Grid>
    </Border>

</UserControl>
