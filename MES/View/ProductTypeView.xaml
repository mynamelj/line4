<UserControl x:Class="MES.View.ProductTypeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MES.View"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:vm="clr-namespace:MES.ViewModel"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <vm:ProductTypeViewModel />
    </UserControl.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <DataGrid Margin="5"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      Background="Transparent"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      CanUserSortColumns="False"
                      ItemsSource="{Binding productTypeViewModels}"
                      SelectedItem="{Binding SelectProduct}">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="SelectedCellsChanged">
                        <i:InvokeCommandAction Command="{Binding DataContext.ProductTypeSelectionChange, RelativeSource={RelativeSource AncestorType=UserControl, Mode=FindAncestor}}" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
                <DataGrid.Columns>

                    <DataGridTemplateColumn Header="编号"
                                            Width="1*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ProductID}"
                                           Height="25"
                                           Margin="10,0"
                                           Padding="5"
                                           VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="产品类型"
                                            Width="1*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ProductName}"
                                           Height="25"
                                           Margin="10,0"
                                           Padding="5"
                                           VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
            <Button Grid.Row="0"
                    Height="30"
                    MinWidth="90"
                    Margin="10"
                    VerticalAlignment="Center"
                    Command="{Binding FormulaSengCommand}"
                    Content="手动配方下发" />
        </Grid>
        <Border Grid.Column="1"
                Margin="5"
                BorderBrush="Black"
                BorderThickness="0.1">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <GroupBox Header="产品类型修改"
                          Grid.Row="0"
                          Grid.Column="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <DockPanel>
                            <TextBlock Text="编       号"
                                       Margin="10"
                                       Padding="0,6,0,0"
                                       VerticalAlignment="Top" />
                            <TextBox Text="{Binding productID}"
                                     Height="30"
                                     Margin="10"
                                     Padding="6,6,0,0"
                                     VerticalAlignment="Top" />
                        </DockPanel>

                        <DockPanel Grid.Row="0"
                                   Grid.Column="1">
                            <TextBlock Text="产品类型"
                                       Margin="10"
                                       Padding="0,6,0,0"
                                       VerticalAlignment="Top" />
                            <TextBox Text="{Binding productName}"
                                     Height="30"
                                     Margin="10"
                                     Padding="6,6,0,0"
                                     VerticalAlignment="Top" />
                        </DockPanel>

                        <Grid Grid.Row="1" Grid.ColumnSpan="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Row="1"
                                    Grid.Column="0"
                                    Height="30"
                                    MinWidth="90"
                                    Margin="10"
                                    VerticalAlignment="Center"
                                    Command="{Binding AddCommand}"
                                    Content="添加" />

                            <Button Grid.Row="1"
                                    Grid.Column="1"
                                    Height="30"
                                    MinWidth="90"
                                    Margin="10"
                                    VerticalAlignment="Center"
                                    Command="{Binding ModifyCommand}"
                                    Content="修改" />

                            <Button Grid.Row="1"
                                    Grid.Column="2"
                                    Height="30"
                                    MinWidth="90"
                                    Margin="10"
                                    VerticalAlignment="Center"
                                    Command="{Binding DeleteCommand}"
                                    Content="删除" />
                        </Grid>
                       
                    </Grid>
                </GroupBox>

                <GroupBox Header="配置文件复制"
                          Grid.Row="1"
                          Grid.Column="0">

                    <Grid Grid.Row="2"
                          Grid.ColumnSpan="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="0.1*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  Height="30"
                                  Margin="10"
                                  Padding="8,8,0,0"
                                  VerticalAlignment="Top"
                                  DisplayMemberPath="ProductName"
                                  ItemsSource="{Binding productTypeViewModels}"
                                  SelectedItem="{Binding SelectComboProductFrom}"
                                  SelectedValuePath="ProductID">

                        </ComboBox>
                        <TextBlock Text="→"
                                   Grid.Column="1"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Column="2"
                                  Height="30"
                                  Margin="10"
                                  Padding="8,8,0,0"
                                  VerticalAlignment="Top"
                                  DisplayMemberPath="ProductName"
                                  ItemsSource="{Binding productTypeViewModels}"
                                  SelectedItem="{Binding SelectComboProductTo}"
                                  SelectedValuePath="ProductID">

                        </ComboBox>
                        <Button Grid.Row="1"
                                Grid.ColumnSpan="3"
                                Height="30"
                                MinWidth="90"
                                Margin="10"
                                VerticalAlignment="Center"
                                Command="{Binding CopyCommand}"
                                PreviewMouseDown="Button_PreviewMouseDown_1"
                                PreviewMouseUp="Button_PreviewMouseUp"
                                Content="复制配置文件" />

                        <Button Grid.Row="2"
                                Grid.ColumnSpan="3"
                                Height="30"
                                MinWidth="90"
                                Margin="10"
                                VerticalAlignment="Center"
                                Command="{Binding CopyOriginalCommand}"
                                PreviewMouseDown="Button_PreviewMouseDown"
                                PreviewMouseUp="orbtn_PreviewMouseUp"
                                Content="复制原始配置文件到每个型号"
                                Visibility="Collapsed" />

                        <Button Grid.Row="2"
                                Grid.ColumnSpan="3"
                                Height="30"
                                MinWidth="90"
                                Margin="10"
                                VerticalAlignment="Center"
                                Command="{Binding CopyD02Setting}"
                                PreviewMouseDown="Button_PreviewMouseDown"
                                PreviewMouseUp="orbtn_PreviewMouseUp"
                                Content="复制D02配置到所有D型号" />
                    </Grid>

                </GroupBox>
                <Grid Grid.Row="2"
                      Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding TestID}"
                             Grid.Column="0"
                             Height="30"
                             Margin="10"
                             Padding="6,6,0,0"
                             VerticalAlignment="Top" />
                    <Button Grid.Column="1"
                            Height="30"
                            MinWidth="90"
                            Margin="10"
                            VerticalAlignment="Center"
                            Command="{Binding TestCommand}"
                            Content="型号获取测试" />
                </Grid>
                <Grid Grid.Row="3"
                      Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding TestType}"
                             Grid.Column="0"
                             Height="30"
                             Margin="10"
                             Padding="6,6,0,0"
                             VerticalAlignment="Top" />
                    <Button Grid.Column="1"
                            Height="30"
                            MinWidth="90"
                            Margin="10"
                            VerticalAlignment="Center"
                            Command="{Binding ChangeCommand}"
                            Content="换型测试" />
                </Grid>
                <GroupBox Header="配方参数复制"
                          Grid.Row="4"
                          Grid.Column="0">

                    <Grid Grid.Row="2"
                          Grid.ColumnSpan="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="0.1*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  Height="30"
                                  Margin="10"
                                  Padding="8,8,0,0"
                                  VerticalAlignment="Top"
                                  DisplayMemberPath="ProductName"
                                  ItemsSource="{Binding productTypeViewModels}"
                                  SelectedItem="{Binding SelectComboFormulaFrom}"
                                  SelectedValuePath="ProductID">

                        </ComboBox>
                        <TextBlock Text="→"
                                   Grid.Column="1"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Column="2"
                                  Height="30"
                                  Margin="10"
                                  Padding="8,8,0,0"
                                  VerticalAlignment="Top"
                                  DisplayMemberPath="ProductName"
                                  ItemsSource="{Binding productTypeViewModels}"
                                  SelectedItem="{Binding SelectComboFormulaTo}"
                                  SelectedValuePath="ProductID">

                        </ComboBox>
                        <Button Grid.Row="1"
                                Grid.ColumnSpan="3"
                                Height="30"
                                MinWidth="90"
                                Margin="10"
                                VerticalAlignment="Center"
                                Command="{Binding CopyFormulaCommand}"
                                Content="复制配方到" />

                        <Button Grid.Row="2"
                                Grid.ColumnSpan="3"
                                Height="30"
                                MinWidth="90"
                                Margin="10"
                                VerticalAlignment="Center"
                                Command="{Binding CopyAllFormulaCommand}"
                                Content="复制配方到所有" />

                        <Grid Grid.Row="3"
                              Grid.ColumnSpan="3"
                              Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <DockPanel  Grid.Column="0">
                                <TextBlock Text="起始地址"
                                           VerticalAlignment="Center" />
                                <TextBox Text="{Binding StartAddr}"
                                         Height="30"
                                         Margin="10"
                                         Padding="6,6,0,0"
                                         VerticalAlignment="Top" />
                            </DockPanel>
                            <DockPanel  Grid.Column="1">
                                <TextBlock Text="螺丝数量"
                                           VerticalAlignment="Center" />
                                <TextBox Text="{Binding Count}"
                                         Height="30"
                                         Margin="10"
                                         Padding="6,6,0,0"
                                         VerticalAlignment="Top" />
                            </DockPanel>
                            <Button Grid.Column="2"
                                    Height="30"
                                    MinWidth="90"
                                    Margin="10"
                                    VerticalAlignment="Center"
                                    Command="{Binding AddFormulaDataCommand}"
                                    Content="配方添加" />
                        </Grid>

                    </Grid>

                </GroupBox>
            </Grid>
        </Border>

    </Grid>
</UserControl>
