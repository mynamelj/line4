<Window x:Class="TSWeighingSystem.Views.Set.PLC设置.ViewPLCTagCfg"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:sys="clr-namespace:System;assembly=mscorlib" 
	    WindowState="Maximized" WindowStartupLocation="CenterScreen"
        Title="标签配置界面" Height="600" Width="1024">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="0" Margin="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBox FontSize="18" Margin="2" Text="{Binding EditGroup.GroupName}" ></TextBox>
                    <ComboBox Grid.Column="1"  FontSize="18" Margin="2" SelectedValue="{Binding EditGroup.GroupType}">
                        <sys:String>AsyncGroup</sys:String>
                        <sys:String>NormalGroup</sys:String>
                    </ComboBox>
                    <TextBox Grid.Column="2"  FontSize="18" Margin="2"   Text="{Binding EditGroup.CheckIntervel}"></TextBox>
                    <TextBox Grid.Column="3"  FontSize="18" Margin="2" Text="{Binding EditGroup.Comment}"></TextBox>
                </Grid>

                <DataGrid Grid.Row="1" BorderBrush="Black" BorderThickness="1" Margin="2" IsReadOnly="True" GridLinesVisibility="All"  AutoGenerateColumns="False" CanUserAddRows="False" SelectionChanged="DataGrid_SelectionChanged" ItemsSource="{Binding ListGroup}" SelectedValue="{Binding SelectGroup}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="组名" Width="*" Binding="{Binding  GroupName}"/>
                        <DataGridTextColumn Header="组类型" Width="*" Binding="{Binding  GroupType}"/>
                        <DataGridTextColumn Header="轮训间隔(毫秒)" Width="*" Binding="{Binding  CheckIntervel}"/>
                        <DataGridTextColumn Header="备注" Width="*" Binding="{Binding  Comment}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Grid.RowSpan="2">
                    <Button Margin="5" FontSize="16" Click="BtnClickAddGroup">添加</Button>
                    <Button Margin="5" FontSize="16" Click="BtnClickModify">修改</Button>
                    <Button Margin="5" FontSize="16" Click="BtnClickDelete">删除</Button>
                </StackPanel>
            </Grid>
        </Border>
        
        <Border BorderBrush="Black" BorderThickness="1" Grid.Row="1" Margin="5">
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBox FontSize="18" Margin="2" Text="{Binding EditTag.TagName}" Grid.Column="0"></TextBox>
                    <TextBox FontSize="18" Margin="2" Text="{Binding EditTag.PlcDevice}" Grid.Column="1"></TextBox>
                    <TextBox FontSize="18" Margin="2" Text="{Binding EditTag.TagAddress}" Grid.Column="2"></TextBox>
                    <ComboBox FontSize="18" Margin="2" Text="{Binding EditTag.TagType}" Grid.Column="3">
                        <sys:String>BOOL</sys:String>
                        <sys:String>SHORT</sys:String>
                        <sys:String>USHORT</sys:String>
                        <sys:String>INT</sys:String>
                        <sys:String>UINT</sys:String>
                        <sys:String>FLOAT</sys:String>
                    </ComboBox>
                    <TextBox FontSize="18" Margin="2" Text="{Binding EditTag.DefaultValue}" Grid.Column="4"></TextBox>
                    <TextBox FontSize="18" Margin="2" Text="{Binding EditTag.Comment}" Grid.Column="5"></TextBox>
                </Grid>

                <DataGrid Grid.Row="1" BorderBrush="Black" BorderThickness="1" Margin="2" GridLinesVisibility="All"  ItemsSource="{Binding ListTag}"
                           IsReadOnly="True" AutoGenerateColumns="False" CanUserAddRows="False" SelectedValue="{Binding SelectTag}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="数据名称" Width="*" Binding="{Binding TagName}"/>
                        <DataGridTextColumn Header="设备名称" Width="*" Binding="{Binding PlcDevice}"/>
                        <DataGridTextColumn Header="数据地址" Width="*" Binding="{Binding TagAddress}"/>
                        <DataGridTextColumn Header="数据类型" Width="*" Binding="{Binding TagType}"/>
                        <DataGridTextColumn Header="初始值" Width="*" Binding="{Binding DefaultValue}"/>
                        <DataGridTextColumn Header="备注" Width="*" Binding="{Binding Comment}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Grid.RowSpan="2">
                    <Button Margin="5" FontSize="16" Click="BtnClickAddTag">添加</Button>
                    <Button Margin="5" FontSize="16" Click="BtnClickModifyTag">修改</Button>
                    <Button Margin="5" FontSize="16" Click="BtnClickDeleteTag">删除</Button>
                </StackPanel>
            </Grid>
        </Border>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Grid.Row="2" FontSize="18" HorizontalAlignment="Right" Margin="5" Click="btnClickSaveCs">cs生成</Button>
            <Button Grid.Row="2" FontSize="18" HorizontalAlignment="Right" Margin="5" Click="BtnClickSave">xml保存</Button>
        </StackPanel>
        
    </Grid>
</Window>
