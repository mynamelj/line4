<UserControl x:Class="MES.View.GlueMaterialOnOffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MES.View"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MES.ViewModel"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             d:DesignHeight="450"
             d:DesignWidth="800"
             Background="White"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <vm:GlueMaterialOnOffViewModel />
    </UserControl.DataContext>
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="3*" />
        </Grid.RowDefinitions>

        <GroupBox Header="产品型号切换"
                  BorderBrush="Black"
                  BorderThickness="1"
                  Visibility="Collapsed">
            <DockPanel Width="200">

                <WrapPanel HorizontalAlignment="Center"
                           VerticalAlignment="Center" >
                    <TextBlock Text="产品型号"
                               Margin="5">
                    </TextBlock>
                    <Grid>
                        <Ellipse Width="15"
                                 Height="15"
                                 Fill="Transparent"
                                 Stroke="Black"
                                 StrokeThickness="1">

                        </Ellipse>
                        <Label Margin="0.6,1.8,0,0"
                               Content="!"
                               FontSize="10"
                               FontWeight="Bold"
                               ToolTip="仅供修改参数使用,不影响实际产品型号" />
                    </Grid>
                </WrapPanel>

                <ComboBox Grid.Column="2" 
                          Height="30"
                          Margin="10"
                          HorizontalContentAlignment="Center"
                          VerticalContentAlignment="Center"
                          DisplayMemberPath="ProductName"
                          ItemsSource="{Binding productTypes}"
                          SelectedItem="{Binding ProductType}"
                          SelectedValuePath="ProductID">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="SelectionChanged">
                            <i:InvokeCommandAction Command="{Binding ProductTypeChange}"
                                                   CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>

                </ComboBox>
            </DockPanel>
        </GroupBox>

        <Border BorderBrush="Black"
                BorderThickness="1" Grid.Row="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="0.5*" />
                </Grid.ColumnDefinitions>
                <DockPanel Grid.Column="0"
                           VerticalAlignment="Center">
                    <TextBlock Text="扫描胶水物料码"
                               Margin="10"
                               Padding="0,6,0,0"
                               VerticalAlignment="Top" />
                    <TextBox Text="{Binding GlueCode}"
                             Height="30"
                             Margin="10"
                             Padding="6,6,0,0"
                             VerticalAlignment="Top" />
                </DockPanel>

                <!--<DockPanel Grid.Column="1"
                           VerticalAlignment="Center">
                    <TextBlock Text="名称"
                               Margin="10"
                               Padding="0,6,0,0"
                               VerticalAlignment="Top" />
                    <TextBox Text="{Binding MaterialName}"
                             Height="30"
                             Margin="10"
                             Padding="6,6,0,0"
                             VerticalAlignment="Top" />
                </DockPanel>-->

                <DockPanel Grid.Column="1"
                           Grid.ColumnSpan="2"
                           VerticalAlignment="Center">
                    <TextBlock Text="工位号"
                               Margin="10"
                               Padding="0,6,0,0"
                               VerticalAlignment="Top" />
                    <ComboBox Height="30"
                              Margin="10"
                              Padding="8,8,0,0"
                              VerticalAlignment="Top"
                              ItemsSource="{Binding LocationList}"
                              SelectedIndex="{Binding LocationIndex}"
                              SelectedValue="{Binding LocationNo}" />
                </DockPanel>

                <!--<DockPanel Grid.Column="3"
                           VerticalAlignment="Center">
                    <TextBlock Text="料箱号"
                               Margin="5,10"
                               Padding="0,6,0,0"
                               VerticalAlignment="Top" />
                    <ComboBox x:Name="BoxNoComboBox"
                              Height="30"
                              Margin="10"
                              Padding="8,8,0,0"
                              VerticalAlignment="Top"
                              ItemsSource="{Binding BoxNoList}"
                              SelectedValue="{Binding BoxNo}" />
                </DockPanel>-->

                <Button x:Name="MaterialOnButton"
                        Grid.Column="3"
                        Height="30"
                        Margin="10"
                        VerticalAlignment="Center"
                        Command="{Binding MaterialOnCommand}"
                        Content="上料" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                BorderBrush="Black"
                BorderThickness="1,0,1,1">
            <TextBox Text="{Binding ErrorMsg}"
                     BorderThickness="0"
                     Margin="10"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontSize="20"
                     Foreground="{Binding Color}"
                     TextWrapping="Wrap"
                     IsReadOnly="True" />
        </Border>

        <DataGrid Grid.Row="3"
                  AutoGenerateColumns="False"
                  BorderBrush="Black"
                  BorderThickness="1,0,1,1"
                  CanUserAddRows="False"
                  ItemsSource="{Binding GlueOnLineList}"
                  IsReadOnly="True">

            <DataGrid.Columns>
                <DataGridTemplateColumn Header="操作"
                                        Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Height="30"
                                    MinWidth="90"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.MaterialOffLineCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}}"
                                    CommandParameter="{Binding .}"
                                    Content="下料" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="胶水码"
                                        Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding GlueCode}"
                                       Margin="10,0"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!--<DataGridTemplateColumn Header="物料名称"
                                        Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding MaterialName}"
                                       Margin="10,0"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="零件编码"
                                        Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding MaterialCode}"
                                       Margin="10,0"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
               
                <DataGridTemplateColumn Header="批次号"
                                        Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Batch}"
                                       Margin="10,0"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>-->

                <DataGridTemplateColumn Header="工位号"
                                        Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding LocationNo}"
                                       Margin="10,0"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="扫码获取的剩余时间(s)"
                                        Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RestDateTime}"
                                       Margin="10,0"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="当前剩余时间(s)"
                                        Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RestDateTimeNow}"
                                       Margin="10,0"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOverTime}"
                                                         Value="No">
                                                <Setter Property="Foreground"
                                                        Value="Green" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsOverTime}"
                                                         Value="Yes">
                                                <Setter Property="Foreground"
                                                        Value="Red" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="扫码时间"
                                        Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DateTime}"
                                       Margin="10,0"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="MES返回的信息"
                                        Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding MesMsg}"
                                       Margin="10,0"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="强制删除"
                                        Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Height="30"
                                    MinWidth="90"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.MaterialDeleteCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}}"
                                    CommandParameter="{Binding .}"
                                    Content="强制删除" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!--<DataGridTemplateColumn Header="料箱号"
                                        Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding BoxNo}"
                                       Margin="10,0"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>-->

            </DataGrid.Columns>

        </DataGrid>
    </Grid>
</UserControl>
