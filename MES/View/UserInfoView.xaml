<UserControl x:Class="MES.View.UserInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MES.View"
             xmlns:vm="clr-namespace:MES.ViewModel"
             mc:Ignorable="d" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.DataContext>
        <vm:UserInfoViewModel/>
    </UserControl.DataContext>
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="3*" />
        </Grid.RowDefinitions>

        <Border BorderBrush="Black"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <DockPanel Grid.Column="0"
                           VerticalAlignment="Center">
                    <TextBlock Text="用户名"
                               Margin="10"
                               Padding="0,6,0,0"
                               VerticalAlignment="Top" />
                    <TextBox Text="{Binding UserName}"
                             Height="30"
                             Margin="10"
                             Padding="6,6,0,0"
                             VerticalAlignment="Top" />
                </DockPanel>

                <DockPanel Grid.Column="1"
                           VerticalAlignment="Center">
                    <TextBlock Text="密码"
                               Margin="10"
                               Padding="0,6,0,0"
                               VerticalAlignment="Top" />
                    <PasswordBox Password=""
                             Height="30" x:Name="password"
                             Margin="10"
                             Padding="6,6,0,0"
                             VerticalAlignment="Top" >
                        <!--<i:Interaction.Triggers>
                            <i:EventTrigger EventName="PasswordChanged">
                                <i:InvokeCommandAction Command="{Binding PasswordChangeCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=PasswordBox}}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>-->
                    </PasswordBox>

                </DockPanel>
                <TextBox x:Name="txtpwd" Visibility="Collapsed" Text="{Binding Password}" TextChanged="txtpwd_TextChanged" DockPanel.Dock="Bottom"/>

                <WrapPanel Grid.Column="3"
                        VerticalAlignment="Center" >

                    <Button Height="30"
                        Margin="10" MinWidth="90" Click="Button_Click"
                        Command="{Binding AddCommand}"
                        Content="新增" />
                    <Button Height="30" MinWidth="90"
                                    VerticalAlignment="Center"
                                    Command="{Binding EditCommand}" Click="Button_Click_1"
                                    CommandParameter="{Binding SelectUser}"
                                    Content="修改" Margin="10"/>
                    <Button Height="30" MinWidth="90"
                                    VerticalAlignment="Center"
                                    Command="{Binding DeleteCommand}"
                                    CommandParameter="{Binding SelectUser}"
                                    Content="删除" Margin="10"/>
                </WrapPanel>

            </Grid>
        </Border>


        <DataGrid Grid.Row="2"
                  AutoGenerateColumns="False"
                  BorderBrush="Black"
                  BorderThickness="1,0,1,1"
                  CanUserAddRows="False"
                  ItemsSource="{Binding UserList}"
                  SelectedItem="{Binding SelectUser}">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="SelectedCellsChanged">
                    <i:InvokeCommandAction Command="{Binding SelectionChange}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
            <DataGrid.Columns>

                <DataGridTemplateColumn Header="用户名"
                                        Width="1*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding UserName}" Padding="5"
                                       Margin="10,0" Height="25"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!--<DataGridTemplateColumn Header="操作"
                                        Width="1*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <WrapPanel>
                                <Button Height="30" MinWidth="90"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}}"
                                    CommandParameter="{Binding .}"
                                    Content="修改" />
                                <Button Height="30" MinWidth="90"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}}"
                                    CommandParameter="{Binding .}"
                                    Content="删除" />
                            </WrapPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>-->
            </DataGrid.Columns>

        </DataGrid>
    </Grid>
</UserControl>
