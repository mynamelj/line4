<Window x:Class="MES.View.CopyToView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:MES.View"
        xmlns:vm="clr-namespace:MES.ViewModel"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d"
        WindowState="Normal"
        WindowStartupLocation="CenterScreen"
        Height="220"
        Width="400"
        Background="White">
    <Window.DataContext>
        <vm:CopyToViewModel />
    </Window.DataContext>

    <StackPanel>
        <DockPanel>
            <TextBlock Text="产品型号"
                       Margin="5"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
            <ComboBox Height="40"
                      Margin="10"
                      FontSize="20"
                      HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center"
                      DisplayMemberPath="ProductName"
                      ItemsSource="{Binding productTypes}"
                      SelectedItem="{Binding ProductType}"
                      SelectedValuePath="ProductID">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="SelectionChanged">
                        <i:InvokeCommandAction Command="{Binding ProductTypeChange}"
                                               CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>

            </ComboBox>
        </DockPanel>
        <DockPanel VerticalAlignment="Center">
            <TextBlock Text="工  位  号"
                       Margin="5"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center" />
            <ComboBox Name="NumberBox"
                      Height="40"
                      Margin="10"
                      FontSize="20"
                      HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Number"
                      ItemsSource="{Binding LocationList}"
                      SelectedItem="{Binding LocationItem}">
            </ComboBox>

        </DockPanel>
        <Button Content="复制" Margin="10" Height="40" Width="100" HorizontalAlignment="Right"
                Command="{Binding CopyCommand}" />

    </StackPanel>
</Window>
