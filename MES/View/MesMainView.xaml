<UserControl x:Class="MES.View.MesMainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:local="clr-namespace:MES.View"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MES.ViewModel"
             Background="White"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MesMainViewModel, IsDesignTimeCreatable=False}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <GroupBox Header="各工站参数设置"
                  Grid.Row="0">
            <ScrollViewer>
                <StackPanel DataContext="{Binding mesSetting}">
                    <TextBlock Text="工站序号(支持多工站上传)"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding StationNumber}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center"
                             IsReadOnly="True" />
                    <TextBlock Text="线别代码"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding Line}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />
                    <TextBlock Text="大机台段别"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding StationID}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />
                    <TextBlock Text="机台编号"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding MachineID}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />
                    <!--<TextBlock Text="操作人员ID"
                           Margin="5"
                           HorizontalAlignment="Center" />
                <TextBox Text="{Binding OPID}"
                         Height="30"
                         Margin="20,0,20,0"
                         Padding="5"
                         HorizontalAlignment="Stretch"
                         TextAlignment="Center" />-->
                    <TextBlock Text="Token"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding Token}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />
                    <TextBlock Text="固资SN"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding FixSN}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />
                    <TextBlock Text="模号"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding Mold}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />
                    <!--<TextBlock Text="物料码数量"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding MaterialCount}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />-->
                    <TextBlock Text="精追料扫码数量"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding ScanMaterialCount}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />
                    <TextBlock Text="批追料数量"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding BatchMaterialCount}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />
                    <TextBlock Text="批追料名称(多个时逗号,隔开)"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding BatchMaterialName}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />
                    <TextBlock Text="分钉箱数量"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding BoxCount}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />
                    <TextBlock Text="文件删除周期(天)"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding PictureSaveTime}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />
                    <TextBlock Text="原图片文件地址"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <Grid Margin="20,0,20,0"
                          HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="30" />
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding PictureFilePath}"
                                 Height="30"
                                 Padding="5"
                                 TextAlignment="Center"
                                 IsReadOnly="True" />
                        <Button Grid.Column="1"
                                BorderBrush="LightSlateGray"
                                BorderThickness="0,1,1,1"
                                Command="{Binding DataContext.GetFilePathCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}">
                            <Button.Content>
                                <Path Width="20"
                                      Height="20"
                                      Data="M912 208H427.872l-50.368-94.176A63.936 63.936 0 0 0 321.056 80H112c-35.296 0-64 28.704-64 64v736c0 35.296 28.704 64 64 64h800c35.296 0 64-28.704 64-64v-608c0-35.296-28.704-64-64-64z m-800-64h209.056l68.448 128H912v97.984c-0.416 0-0.8-0.128-1.216-0.128H113.248c-0.416 0-0.8 0.128-1.248 0.128V144z m0 736v-96l1.248-350.144 798.752 1.216V784h0.064v96H112z"
                                      Fill="Black"
                                      Stretch="Fill">
                                </Path>
                            </Button.Content>
                        </Button>
                    </Grid>
                    <TextBlock Text="已上传图片文件地址"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <Grid Margin="20,0,20,0"
                          HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="30" />
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding PictureUploadedFilePath}"
                                 Height="30"
                                 Padding="5"
                                 TextAlignment="Center"
                                 IsReadOnly="True" />
                        <Button Grid.Column="1"
                                BorderBrush="LightSlateGray"
                                BorderThickness="0,1,1,1"
                                Command="{Binding DataContext.GetUploadedFilePathCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}">
                            <Button.Content>
                                <Path Width="20"
                                      Height="20"
                                      Data="M912 208H427.872l-50.368-94.176A63.936 63.936 0 0 0 321.056 80H112c-35.296 0-64 28.704-64 64v736c0 35.296 28.704 64 64 64h800c35.296 0 64-28.704 64-64v-608c0-35.296-28.704-64-64-64z m-800-64h209.056l68.448 128H912v97.984c-0.416 0-0.8-0.128-1.216-0.128H113.248c-0.416 0-0.8 0.128-1.248 0.128V144z m0 736v-96l1.248-350.144 798.752 1.216V784h0.064v96H112z"
                                      Fill="Black"
                                      Stretch="Fill">
                                </Path>
                            </Button.Content>
                        </Button>
                    </Grid>
                    <TextBlock Text="映射盘地址"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <Grid Margin="20,0,20,0"
                          HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="30" />
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding MappingDiskPath}"
                                 Height="30"
                                 Padding="5"
                                 TextAlignment="Center" />
                        <Button Grid.Column="1"
                                BorderBrush="LightSlateGray"
                                BorderThickness="0,1,1,1"
                                Command="{Binding DataContext.GetMappingDiskPathCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}">
                            <Button.Content>
                                <Path Width="20"
                                      Height="20"
                                      Data="M912 208H427.872l-50.368-94.176A63.936 63.936 0 0 0 321.056 80H112c-35.296 0-64 28.704-64 64v736c0 35.296 28.704 64 64 64h800c35.296 0 64-28.704 64-64v-608c0-35.296-28.704-64-64-64z m-800-64h209.056l68.448 128H912v97.984c-0.416 0-0.8-0.128-1.216-0.128H113.248c-0.416 0-0.8 0.128-1.248 0.128V144z m0 736v-96l1.248-350.144 798.752 1.216V784h0.064v96H112z"
                                      Fill="Black"
                                      Stretch="Fill">
                                </Path>
                            </Button.Content>
                        </Button>
                    </Grid>
                    <TextBlock Text="相机序号(0=关闭多相机功能)"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding CCDNumber}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />
                    <TextBlock Text="条码校验规则"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding RegexRule}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />
                    <TextBlock Text="状态上传间隔时间(秒)"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding StatusUploadTime}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />
                    <TextBlock Text="报警上传间隔时间(秒)"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding AlarmUploadTime}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />

                    <TextBlock Text="扫码进站SN码长度(0=关闭扫码进站)"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding SNCodeLen}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />

                    <TextBlock Text="扫码检查材料合法性码长度(0=关闭扫码FeedingCheck)"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding FeedingSNCodeLen}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />
                    
                    <TextBlock Text="条码规则(为空时不校验)"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding CodeRule}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />

                    <TextBlock Text="直接给PLC条码信息(1=扫码不校验直接给条码信号)"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding IsGivePlcCode}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />

                    <TextBlock Text="是否进站需要SN(0=不要，1=要)"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding IsNgCheckInStation}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />

                    <TextBlock Text="是否为选垫工位(0=不是，1=是)"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding IsSelectStation}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />

                    <TextBlock Text="是否为胶水上料工位(0=不是，1=是)"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding IsGlueStation}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />
                    <TextBlock Text="是否为手动工位(0=不是，1=是)"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding IsMauaStation}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />
                    <TextBlock Text="是否为核对载具码工位(0=不是，1=是)"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding IsCarryCheckStation}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />
                    <!--<TextBlock Text="设定参数上传间隔时间(分钟)"
                               Margin="5"
                               HorizontalAlignment="Center" />
                    <TextBox Text="{Binding SetParaUploadTime}"
                             Height="30"
                             Margin="20,0,20,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             TextAlignment="Center" />-->
                </StackPanel>
            </ScrollViewer>
        </GroupBox>
        <Grid Grid.Row="0"
              Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <GroupBox Header="产品型号切换">
                <StackPanel>

                    <WrapPanel HorizontalAlignment="Center">
                        <TextBlock Text="产品型号修改"
                                   Margin="5">
                        </TextBlock>
                        <Grid>
                            <Ellipse Width="15"
                                     Height="15"
                                     Fill="Transparent"
                                     Stroke="Black"
                                     StrokeThickness="1">

                            </Ellipse>
                            <Label Margin="0.6,1.8,0,0"
                                   Content="!"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   ToolTip="仅供修改参数使用,不影响实际产品型号" />
                        </Grid>
                    </WrapPanel>

                    <ComboBox Grid.Column="2"
                              Height="50"
                              Margin="10"
                              HorizontalContentAlignment="Center"
                              VerticalContentAlignment="Center"
                              DisplayMemberPath="ProductName"
                              FontSize="20"
                              ItemsSource="{Binding productTypes}"
                              SelectedItem="{Binding ProductType, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="ProductID">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectionChanged">
                                <i:InvokeCommandAction Command="{Binding ProductTypeChange}"
                                                       CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>

                    </ComboBox>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="工站选择"
                      Grid.Row="1">
                <StackPanel>
                    <ComboBox Name="NumberBox"
                              Text="{Binding SelectText}"
                              Height="50"
                              Margin="10"
                              Padding="5"
                              VerticalAlignment="Center"
                              HorizontalContentAlignment="Center"
                              VerticalContentAlignment="Center"
                              FontSize="20"
                              IsEditable="False"
                              IsReadOnly="True"
                              ItemsSource="{Binding SelectNumber}"
                              SelectedIndex="{Binding SelectId}">
                        <!--<ComboBox Name="Box"
                              Height="30"
                              Margin="10"
                              Padding="8,8,0,0"
                              VerticalAlignment="Top"
                              ItemsSource="{Binding SelectNumber}"
                              SelectedIndex="0"
                              SelectedValue="{Binding SelectText}" >-->
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectionChanged">
                                <i:InvokeCommandAction Command="{Binding SelectionChangedCommand}"
                                                       CommandParameter="{Binding SelectedIndex, ElementName=NumberBox}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </ComboBox>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="各工站接口地址设置"
                      Grid.Row="2">

                <ScrollViewer>
                    <StackPanel DataContext="{Binding apiSetting}"
                                IsEnabled="{Binding DataContext.CanEdit, RelativeSource={RelativeSource AncestorType={x:Type GroupBox}}}">
                        <TextBlock Text="工站序号"
                                   Margin="5"
                                   HorizontalAlignment="Center" />
                        <TextBox Text="{Binding StationNumber}"
                                 Height="30"
                                 Margin="20,0,20,0"
                                 Padding="5"
                                 HorizontalAlignment="Stretch"
                                 TextAlignment="Center"
                                 IsReadOnly="True" />
                        <TextBlock Text="基础地址"
                                   Margin="5"
                                   HorizontalAlignment="Center" />
                        <TextBox Text="{Binding BaseUrl}"
                                 Height="30"
                                 Margin="20,0,20,0"
                                 Padding="5"
                                 HorizontalAlignment="Stretch"
                                 TextAlignment="Center" />
                        <TextBlock Text="产品切型"
                                   Margin="5"
                                   HorizontalAlignment="Center" />
                        <TextBox Text="{Binding ChangeProductTypeApi}"
                                 Height="30"
                                 Margin="20,0,20,0"
                                 Padding="5"
                                 HorizontalAlignment="Stretch"
                                 TextAlignment="Center" />
                        <TextBlock Text="图片上传"
                                   Margin="5"
                                   HorizontalAlignment="Center" />
                        <TextBox Text="{Binding FileUploadApi}"
                                 Height="30"
                                 Margin="20,0,20,0"
                                 Padding="5"
                                 HorizontalAlignment="Stretch"
                                 TextAlignment="Center" />
                        <TextBlock Text="产品进站"
                                   Margin="5"
                                   HorizontalAlignment="Center" />
                        <TextBox Text="{Binding CheckINApi}"
                                 Height="30"
                                 Margin="20,0,20,0"
                                 Padding="5"
                                 HorizontalAlignment="Stretch"
                                 TextAlignment="Center" />
                        <TextBlock Text="获取重量"
                                   Margin="5"
                                   HorizontalAlignment="Center" />
                        <TextBox Text="{Binding QuerySNApi}"
                                 Height="30"
                                 Margin="20,0,20,0"
                                 Padding="5"
                                 HorizontalAlignment="Stretch"
                                 TextAlignment="Center" />
                        <TextBlock Text="Link或核对材料"
                                   Margin="5"
                                   HorizontalAlignment="Center" />
                        <TextBox Text="{Binding LinkCompApi}"
                                 Height="30"
                                 Margin="20,0,20,0"
                                 Padding="5"
                                 HorizontalAlignment="Stretch"
                                 TextAlignment="Center" />
                        <TextBlock Text="数据收集"
                                   Margin="5"
                                   HorizontalAlignment="Center" />
                        <TextBox Text="{Binding DataCollectionApi}"
                                 Height="30"
                                 Margin="20,0,20,0"
                                 Padding="5"
                                 HorizontalAlignment="Stretch"
                                 TextAlignment="Center" />
                        <TextBlock Text="产品出站"
                                   Margin="5"
                                   HorizontalAlignment="Center" />
                        <TextBox Text="{Binding CheckOutApi}"
                                 Height="30"
                                 Margin="20,0,20,0"
                                 Padding="5"
                                 HorizontalAlignment="Stretch"
                                 TextAlignment="Center" />
                        <TextBlock Text="产品出站"
                                   Margin="5"
                                   HorizontalAlignment="Center" />
                        <TextBox Text="{Binding CheckOutApi}"
                                 Height="30"
                                 Margin="20,0,20,0"
                                 Padding="5"
                                 HorizontalAlignment="Stretch"
                                 TextAlignment="Center" />
                        <!--<TextBlock Text="设备报警"
                   Margin="5"
                   HorizontalAlignment="Center" />
        <TextBox Text="{Binding AlarmApi}"
                 Height="30"
                 Margin="20,0,20,0"
                 Padding="5"
                 HorizontalAlignment="Stretch"
                 TextAlignment="Center" />
        <TextBlock Text="设备状态"
                   Margin="5"
                   HorizontalAlignment="Center" />
        <TextBox Text="{Binding StatusApi}"
                 Height="30"
                 Margin="20,0,20,0"
                 Padding="5"
                 HorizontalAlignment="Stretch"
                 TextAlignment="Center" />
        <TextBlock Text="OEE"
                   Margin="5"
                   HorizontalAlignment="Center" />
        <TextBox Text="{Binding OEEApi}"
                 Height="30"
                 Margin="20,0,20,0"
                 Padding="5"
                 HorizontalAlignment="Stretch"
                 TextAlignment="Center" />-->

                        <TextBlock Text="机台批次上料"
                                   Margin="5"
                                   HorizontalAlignment="Center" />
                        <TextBox Text="{Binding CompSNCheckout}"
                                 Height="30"
                                 Margin="20,0,20,0"
                                 Padding="5"
                                 HorizontalAlignment="Stretch"
                                 TextAlignment="Center" />

                        <TextBlock Text="机台批次下料"
                                   Margin="5"
                                   HorizontalAlignment="Center" />
                        <TextBox Text="{Binding CompSNOffline}"
                                 Height="30"
                                 Margin="20,0,20,0"
                                 Padding="5"
                                 HorizontalAlignment="Stretch"
                                 TextAlignment="Center" />

                        <TextBlock Text="机台批次检查"
                                   Margin="5"
                                   HorizontalAlignment="Center" />
                        <TextBox Text="{Binding CompSNChange}"
                                 Height="30"
                                 Margin="20,0,20,0"
                                 Padding="5"
                                 HorizontalAlignment="Stretch"
                                 TextAlignment="Center" />

                        <TextBlock Text="胶水上下料"
                                   Margin="5"
                                   HorizontalAlignment="Center" />
                        <TextBox Text="{Binding GlueCheckOut}"
                                 Height="30"
                                 Margin="20,0,20,0"
                                 Padding="5"
                                 HorizontalAlignment="Stretch"
                                 TextAlignment="Center" />
                        <!--<TextBlock Text="机台下料"
                   Margin="5"
                   HorizontalAlignment="Center" />
                        <TextBox Text="{Binding GlueOffLine}"
                 Height="30"
                 Margin="20,0,20,0"
                 Padding="5"
                 HorizontalAlignment="Stretch"
                 TextAlignment="Center" />-->

                        <TextBlock Text="检查材料合法性"
                                   Margin="5"
                                   HorizontalAlignment="Center" />
                        <TextBox Text="{Binding FeedingCheck}"
                                 Height="30"
                                 Margin="20,0,20,0"
                                 Padding="5"
                                 HorizontalAlignment="Stretch"
                                 TextAlignment="Center" />

                        <TextBlock Text="核对载具或托盘"
                                   Margin="5"
                                   HorizontalAlignment="Center" />
                        <TextBox Text="{Binding CarrierCheck}"
                                 Height="30"
                                 Margin="20,0,20,0"
                                 Padding="5"
                                 HorizontalAlignment="Stretch"
                                 TextAlignment="Center" />

                        <TextBlock Text="载具绑定/解绑"
                                   Margin="5"
                                   HorizontalAlignment="Center" />
                        <TextBox Text="{Binding CarrierBind}"
                                 Height="30"
                                 Margin="20,0,20,0"
                                 Padding="5"
                                 HorizontalAlignment="Stretch"
                                 TextAlignment="Center" />

                        <TextBlock Text="发送打印信号"
                                   Margin="5"
                                   HorizontalAlignment="Center" />
                        <TextBox Text="{Binding CodeSoftPrint}"
                                 Height="30"
                                 Margin="20,0,20,0"
                                 Padding="5"
                                 HorizontalAlignment="Stretch"
                                 TextAlignment="Center" />

                        <TextBlock Text="设定参数上报"
                                   Margin="5"
                                   HorizontalAlignment="Center" />
                        <TextBox Text="{Binding GetPara}"
                                 Height="30"
                                 Margin="20,0,20,0"
                                 Padding="5"
                                 HorizontalAlignment="Stretch"
                                 TextAlignment="Center" />

                        <TextBlock Text="机台状态"
                                   Margin="5"
                                   HorizontalAlignment="Center" />
                        <TextBox Text="{Binding StatusApi}"
                                 Height="30"
                                 Margin="20,0,20,0"
                                 Padding="5"
                                 HorizontalAlignment="Stretch"
                                 TextAlignment="Center" />

                        <TextBlock Text="机台报警"
                                   Margin="5"
                                   HorizontalAlignment="Center" />
