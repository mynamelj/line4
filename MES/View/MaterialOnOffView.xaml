<UserControl x:Class="MES.View.MaterialOnOffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:local="clr-namespace:MES.View"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:vm="clr-namespace:MES.ViewModel"
             d:DesignHeight="450"
             d:DesignWidth="800"
             Background="White"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <vm:MaterialOnOffViewModel />
    </UserControl.DataContext>
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="1.8*" />
            <RowDefinition Height="1.9*" />
            <RowDefinition Height="1.2*" />
            <RowDefinition Height="2*" />
        </Grid.RowDefinitions>

        <GroupBox Header="产品型号切换"
                  BorderBrush="Black"
                  BorderThickness="1"
                  Visibility="Collapsed">
            <DockPanel Width="200">

                <WrapPanel HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                    <TextBlock Text="产品型号"
                               Margin="5">
                    </TextBlock>
                    <Grid>
                        <Ellipse Width="15"
                                 Height="15"
                                 Fill="Transparent"
                                 Stroke="Black"
                                 StrokeThickness="1">

                        </Ellipse>
                        <Label Margin="0.6,1.8,0,0"
                               Content="!"
                               FontSize="10"
                               FontWeight="Bold"
                               ToolTip="仅供修改参数使用,不影响实际产品型号" />
                    </Grid>
                </WrapPanel>

                <ComboBox Grid.Column="2"
                          Height="30"
                          Margin="10"
                          HorizontalContentAlignment="Center"
                          VerticalContentAlignment="Center"
                          DisplayMemberPath="ProductName"
                          ItemsSource="{Binding productTypes}"
                          SelectedItem="{Binding ProductType}"
                          SelectedValuePath="ProductID">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="SelectionChanged">
                            <i:InvokeCommandAction Command="{Binding ProductTypeChange}"
                                                   CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>

                </ComboBox>
            </DockPanel>
        </GroupBox>

        <Border Grid.Row="0"
                BorderBrush="Black"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="1.7*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Column="0"
                           Grid.ColumnSpan="2"
                           VerticalAlignment="Center">
                    <TextBlock Text="扫描物料批次码"
                               Margin="10"
                               Padding="0,6,0,0"
                               VerticalAlignment="Center" />
                    <TextBox Text="{Binding GlueCode}"
                             Height="40"
                             Margin="10"
                             Padding="6,0,0,0"
                             VerticalAlignment="Center"
                             VerticalContentAlignment="Center" />
                </DockPanel>

                <DockPanel Grid.Row="1"
                           Grid.Column="0"
                           Visibility="Collapsed">
                    <TextBlock Text="箱号"
                               Margin="10"
                               Padding="0,6,0,0"
                               VerticalAlignment="Center" />
                    <ComboBox Height="40"
                              Margin="10"
                              Padding="8,8,0,0"
                              VerticalAlignment="Center"
                              FontSize="20"
                              SelectedIndex="0"
                              SelectedValue="{Binding BoxNo}">
                        <sys:String>无</sys:String>
                        <sys:String>1</sys:String>
                        <sys:String>2</sys:String>
                        <sys:String>3</sys:String>
                        <sys:String>4</sys:String>
                    </ComboBox>
                </DockPanel>

                <DockPanel Grid.Column="2"
                           VerticalAlignment="Center">
                    <TextBlock Text="工位号"
                               Margin="10"
                               Padding="0,6,0,0"
                               VerticalAlignment="Center" />
                    <ComboBox Name="NumberBox"
                              Height="40"
                              Margin="10"
                              Padding="8,8,0,0"
                              VerticalAlignment="Center"
                              FontSize="20"
                              ItemsSource="{Binding LocationList}"
                              SelectedIndex="{Binding LocationIndex}"
                              SelectedValue="{Binding LocationNo}">

                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectionChanged">
                                <i:InvokeCommandAction Command="{Binding SelectionChangedCommand}"
                                                       CommandParameter="{Binding SelectedIndex, ElementName=NumberBox}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>

                    </ComboBox>
                </DockPanel>

                <DockPanel Grid.Row="0"
                           Grid.Column="3"
                           Grid.ColumnSpan="1"
                           VerticalAlignment="Center">
                    <TextBlock Text="物料名称"
                               Margin="10"
                               Padding="0,6,0,0"
                               VerticalAlignment="Center" />
                    <ComboBox Name="MaterialBox"
                              Height="40"
                              Margin="10"
                              Padding="8,8,0,0"
                              VerticalAlignment="Center"
                              FontSize="20"
                              ItemsSource="{Binding MaterialNameList, Mode=TwoWay}"
                              SelectedIndex="0"
                              SelectedValue="{Binding MaterialNameNo}">

                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectionChanged">
                                <i:InvokeCommandAction Command="{Binding MaterialChangedCommand}"
                                                       CommandParameter="{Binding SelectedValue, ElementName=MaterialBox}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </ComboBox>
                </DockPanel>

                <GroupBox Grid.Row="1"
                          Grid.Column="1"
                          Grid.ColumnSpan="1"
                          VerticalAlignment="Center"
                          Visibility="{Binding IsSelectStation}">
                    <DockPanel>
                        <TextBlock Text="选垫灯号"
                                   Margin="0"
                                   Padding="0,6,0,0"
                                   VerticalAlignment="Top"
                                   FontSize="14"
                                   TextWrapping="Wrap" />
                        <TextBox Text="{Binding LightNumber}"
                                 Height="30"
                                 Margin="0"
                                 Padding="6,6,0,0"
                                 VerticalAlignment="Top" />
                    </DockPanel>
                </GroupBox>

                <Border Grid.Row="1"
                        Grid.Column="2"
                        Grid.ColumnSpan="1"
                        VerticalAlignment="Center">
                    <DockPanel Margin="5">
                        <TextBlock Text="物料一次使用数量(注意不要输错)"
                                   Width="120"
                                   Margin="10"
                                   VerticalAlignment="Top"
                                   FontSize="14"
                                   Foreground="Red"
                                   TextWrapping="Wrap" />
                        <TextBox Text="{Binding UseCountOnceSelect}"
                                 Height="30"
                                 VerticalAlignment="Center"
                                 VerticalContentAlignment="Center" />
                    </DockPanel>
                </Border>

                <Button x:Name="MaterialOnButton"
                        Grid.Row="1"
                        Grid.Column="3"
                        Height="30"
                        Margin="20,0,20,0"
                        VerticalAlignment="Center"
                        Command="{Binding MaterialOnCommand}"
                        Content="上料" />

                <Button x:Name="LightConfigButton"
                        Grid.Row="1"
                        Grid.Column="0"
                        Height="30"
                        Margin="20,0,20,0"
                        VerticalAlignment="Center"
                        Command="{Binding LightConfigCommand}"
                        Content="灯号配置"
                        Visibility="{Binding IsSelectStation}" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                BorderBrush="Black"
                BorderThickness="1,0,1,1">
            <TextBox Text="{Binding ErrorMsg}"
                     Margin="10"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     BorderThickness="0"
                     FontSize="20"
                     Foreground="{Binding Color}"
                     IsReadOnly="True"
                     TextWrapping="Wrap" />
        </Border>
        <DockPanel Grid.Row="2"
                   Grid.ColumnSpan="5">
            <ItemsControl ItemsSource="{Binding OpenBoxes}">
                <!--  设置 ItemsPanel 为横向排列  -->
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel HorizontalAlignment="Center"
                                    Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <GroupBox Name="开箱"
                                  Width="300"
                                  Margin="5">
                            <StackPanel>
                                <Button Height="30"
                                        Margin="10"
                                        VerticalAlignment="Center"
                                        Background="LightGreen"
                                        Command="{Binding OpenBoxCommand}"
                                        CommandParameter="{Binding SelectedIndex, ElementName=NumberBox}"
                                        Content="{Binding BoxName}"
                                        IsEnabled="{Binding IsOpenEnable}">
                                </Button>
                                <TextBlock Text="匹配物料码（多个用逗号,隔开）" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBox Text="{Binding CheckCode}"
                                             Width="250" />
                                    <Button Height="30"
                                            VerticalAlignment="Center"
                                            Command="{Binding SaveCommand}"
                                            CommandParameter="{Binding BoxName}"
                                            Content="保存">
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DockPanel>
        <DataGrid Grid.Row="3"
                  AutoGenerateColumns="False"
                  BorderBrush="Black"
                  BorderThickness="1,0,1,1"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  ItemsSource="{Binding GlueOnLineList}">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="操作"
                                        Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Height="30"
                                    MinWidth="90"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.MaterialOffLineCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}}"
                                    CommandParameter="{Binding .}"
                                    Content="下料" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="灯号(选垫专用)"
                                        Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding LightNumber}"
                                       Margin="10,0"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="物料名称"
                                        Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding MaterialName}"
                                       Margin="10,0"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="箱号"
                                        Width="auto"
                                        Visibility="Collapsed">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding BoxNo}"
                                       Margin="10,0"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="一次使用数量"
                                        Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding UseCountOnce}"
                                       Margin="10,0"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="批次码"
                                        Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding GlueCode}"
                                       Margin="10,0"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!--<DataGridTemplateColumn Header="零件编码"
                                        Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding MaterialCode}"
                                       Margin="10,0"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>-->

                <!--<DataGridTemplateColumn Header="批次号"
                                        Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Batch}"
                                       Margin="10,0"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>-->

                <DataGridTemplateColumn Header="工位号"
                                        Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding LocationNo}"
                                       Margin="10,0"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="扫码时间"
                                        Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DateTime}"
                                       Margin="10,0"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="MES返回的信息"
                                        Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding MesMsg}"
                                       Margin="10,0"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="复制到"
                                        Width="auto"
                                        Visibility="Collapsed">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Height="30"
                                    MinWidth="90"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.CopyCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}}"
                                    CommandParameter="{Binding .}"
                                    Content="复制到" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="强制删除"
                                        Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Height="30"
                                    MinWidth="90"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.MaterialDeleteCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}}"
                                    CommandParameter="{Binding .}"
                                    Content="强制删除" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>

        </DataGrid>
    </Grid>
</UserControl>
