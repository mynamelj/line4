<UserControl x:Class="MES.View.NGOnLineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MES.View"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MES.ViewModel" xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             d:DesignHeight="450"
             d:DesignWidth="800"
             Background="White"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <vm:NGOnLineViewModel />
    </UserControl.DataContext>
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="0.2*" />
            <RowDefinition Height="0.3*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="NG上线" FontSize="50" Foreground="Blue" VerticalAlignment="Center" HorizontalAlignment="Center">
            
        </TextBlock>
            <Border BorderBrush="Black"
                BorderThickness="1" Grid.Row="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="0.5*" />
                </Grid.ColumnDefinitions>
                <DockPanel Grid.Column="0"
                           VerticalAlignment="Center">
                    <TextBlock Text="上线条码"
                               Margin="10"
                               Padding="0,6,0,0"
                               VerticalAlignment="Top" />
                    <TextBox Text="{Binding GlueCode}"
                             Height="30"
                             Margin="10"
                             Padding="6,6,0,0"
                             VerticalAlignment="Top" />
                </DockPanel>



                <DockPanel Grid.Column="1" Grid.ColumnSpan="2"
                           VerticalAlignment="Center">
                    <TextBlock Text="工位号"
                               Margin="10"
                               Padding="0,6,0,0"
                               VerticalAlignment="Top" />
                    <ComboBox Name="NumberBox"
                              Height="30"
                              Margin="10"
                              Padding="8,8,0,0"
                              VerticalAlignment="Top"
                              ItemsSource="{Binding LocationList}"
                              SelectedIndex="0"
                              SelectedValue="{Binding LocationNo}" >
                        
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectionChanged">
                                <i:InvokeCommandAction Command="{Binding SelectionChangedCommand}" 
                                   CommandParameter="{Binding SelectedIndex, ElementName=NumberBox}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>

                    </ComboBox>
                </DockPanel>
                
                <!--<DockPanel Grid.Column="2" Grid.ColumnSpan="2"
                           VerticalAlignment="Center">
                    <TextBlock Text="物料名称"
                               Margin="10"
                               Padding="0,6,0,0"
                               VerticalAlignment="Top" />
                    <ComboBox
                              Height="30"
                              Margin="10"
                              Padding="8,8,0,0"
                              VerticalAlignment="Top"
                              ItemsSource="{Binding MaterialNameList,Mode=TwoWay}"
                        SelectedIndex="0"
                              SelectedValue="{Binding MaterialNameNo}" >
                    </ComboBox>
                </DockPanel>-->
                <!--<DockPanel Grid.Column="3"
                           VerticalAlignment="Center">
                    <TextBlock Text="料箱号"
                               Margin="5,10"
                               Padding="0,6,0,0"
                               VerticalAlignment="Top" />
                    <ComboBox x:Name="BoxNoComboBox"
                              Height="30"
                              Margin="10"
                              Padding="8,8,0,0"
                              VerticalAlignment="Top"
                              ItemsSource="{Binding BoxNoList}"
                              SelectedValue="{Binding BoxNo}" />
                </DockPanel>-->

                <Button x:Name="MaterialOnButton"
                        Grid.Column="3"
                        Height="30"
                        Margin="10"
                        VerticalAlignment="Center"
                        Command="{Binding MaterialOnCommand}"
                        Content="上线" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                BorderBrush="Black"
                BorderThickness="1,0,1,1">
            <TextBox Text="{Binding ErrorMsg}"
                       Margin="10"
                        BorderThickness="0"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="20"
                       Foreground="{Binding Color}"
                       TextWrapping="Wrap" IsReadOnly="True"/>
        </Border>

        <!--<DataGrid Grid.Row="2"
                  AutoGenerateColumns="False"
                  BorderBrush="Black"
                  BorderThickness="1,0,1,1"
                  CanUserAddRows="False"
                  ItemsSource="{Binding GlueOnLineList}"
                  IsReadOnly="True">
            <DataGrid.Columns>
                --><!--<DataGridTemplateColumn Header="操作"
                                        Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Height="30" MinWidth="90"
                                    VerticalAlignment="Center"
