<UserControl x:Class="MES.View.ScanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:MES.ViewModel"
             xmlns:local="clr-namespace:MES.View"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d"
             Background="White"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <UserControl.DataContext>
        <vm:ScanViewModel />
    </UserControl.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <GroupBox Header="产品型号切换"
                  BorderBrush="Black"
                  BorderThickness="1">
            <DockPanel Width="200">

                <WrapPanel HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                    <TextBlock Text="产品型号"
                               Margin="5">
                    </TextBlock>
                    <Grid>
                        <Ellipse Width="15"
                                 Height="15"
                                 Fill="Transparent"
                                 Stroke="Black"
                                 StrokeThickness="1">

                        </Ellipse>
                        <Label Margin="0.6,1.8,0,0"
                               Content="!"
                               FontSize="10"
                               FontWeight="Bold"
                               ToolTip="仅供修改参数使用,不影响实际产品型号" />
                    </Grid>
                </WrapPanel>

                <ComboBox Grid.Column="2"
                          Height="30"
                          Margin="10"
                          HorizontalContentAlignment="Center"
                          VerticalContentAlignment="Center"
                          DisplayMemberPath="ProductName"
                          ItemsSource="{Binding productTypes}"
                          SelectedItem="{Binding ProductType}"
                          SelectedValuePath="ProductID">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="SelectionChanged">
                            <i:InvokeCommandAction Command="{Binding ProductTypeChange}"
                                                   CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>

                </ComboBox>
            </DockPanel>
        </GroupBox>
        <Grid Grid.Row="1">
            <Button Height="20"
                    Width="20"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Content="+"
                    Command="{Binding AddCommand}" />
            <ItemsControl  ItemsSource="{Binding ScanSetting}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid  Columns="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <DockPanel>
                                <TextBlock Text="串口号"
                                           Margin="2"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                <TextBox Text="{Binding Com}"
                                         Height="30"
                                         Margin="10,0,10,0"
                                         Padding="5"
                                         HorizontalAlignment="Stretch" />
                            </DockPanel>
                            <DockPanel Grid.Column="1">
                                <TextBlock Text="波特率"
                                           Margin="2"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                <ComboBox SelectedItem="{Binding BaudRate}"
                                          Height="30"
                                          Margin="10,0,10,0"
                                          Padding="5"
                                          HorizontalAlignment="Stretch">
                                    <sys:String>4800</sys:String>
                                    <sys:String>9600</sys:String>
                                    <sys:String>19200</sys:String>
                                    <sys:String>38400</sys:String>
                                    <sys:String>115200</sys:String>
                                </ComboBox>
                            </DockPanel>
                            <DockPanel Grid.Column="2">
                                <TextBlock Text="校验位"
                                           Margin="2"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                <ComboBox SelectedItem="{Binding Parity}"
                                          Height="30"
                                          Margin="10,0,10,0"
                                          Padding="5"
                                          HorizontalAlignment="Stretch">
                                    <sys:String>None</sys:String>
                                    <sys:String>Odd</sys:String>
                                    <sys:String>Even</sys:String>
                                    <sys:String>Mark</sys:String>
                                    <sys:String>Space</sys:String>
                                </ComboBox>
                            </DockPanel>
                            <DockPanel Grid.Column="3">
                                <TextBlock Text="数据位"
                                           Margin="2"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                <ComboBox SelectedItem="{Binding DataBits}"
                                          Height="30"
                                          Margin="10,0,10,0"
                                          Padding="5"
                                          HorizontalAlignment="Stretch">
                                    <sys:String>5</sys:String>
                                    <sys:String>6</sys:String>
                                    <sys:String>7</sys:String>
                                    <sys:String>8</sys:String>
                                </ComboBox>
                            </DockPanel>
                            <DockPanel Grid.Column="4">
                                <TextBlock Text="停止位"
                                           Margin="2"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                <ComboBox SelectedItem="{Binding StopBits}"
                                          Height="30"
                                          Margin="10,0,10,0"
                                          Padding="5"
                                          HorizontalAlignment="Stretch">
                                    <sys:String>None</sys:String>
                                    <sys:String>One</sys:String>
                                    <sys:String>Two</sys:String>
                                    <sys:String>OnePointFive</sys:String>
                                </ComboBox>
                            </DockPanel>
                            <DockPanel Grid.Column="5">
                                <TextBlock Text="结束符"
                                           Margin="2"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                <TextBox Text="{Binding EndLine}"
                                         Height="30"
                                         Margin="10,0,10,0"
                                         Padding="5"
                                         HorizontalAlignment="Stretch" />
                                <Button Height="20"
                                        Content="-"
                                        Width="20"
                                        HorizontalAlignment="Right"
                                        Command="{Binding DataContext.DeleteCommand,RelativeSource= {RelativeSource AncestorType=UserControl,Mode=FindAncestor}}"
                                        CommandParameter="{Binding .}" />
                            </DockPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </Grid>


        <Button Grid.Row="2"
                Width="100"
                Height="30"
                Margin="2"
                Command="{Binding SaveCommand}"
                Content="保存" />
    </Grid>
</UserControl>
