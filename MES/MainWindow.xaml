<Window x:Class="MES.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:MES"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MES"
        Title="MES交互软件"
        Closing="Window_Closing"
        MinWidth="1000"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        mc:Ignorable="d"
        Loaded="Window_Loaded"
        d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel, IsDesignTimeCreatable=False}">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding Loaded}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <TabControl SelectionChanged="TabControl_SelectionChanged">
            <TabItem Header="消息"
                     Width="80"
                     Height="30"
                     Margin="2,0"
                     HorizontalAlignment="Center">
                <Frame x:Name="close"
                       NavigationUIVisibility="Hidden"
                       Source="View/MessageView.xaml" />
            </TabItem>
            <TabItem Header="MES"
                     Name="mesTab"
                     Width="80"
                     Height="30"
                     Margin="2,0"
                     HorizontalAlignment="Center">
           
            </TabItem>
            <TabItem Header="PLC"
                     Width="80"
                     Height="30"
                     Margin="2,0"
                     HorizontalAlignment="Center">
                <Frame NavigationUIVisibility="Hidden"
                       Source="View/PLCSetView.xaml" />
            </TabItem>
            <TabItem Header="扫码枪"
                     Width="80"
                     Height="30"
                     Margin="2,0"
                     HorizontalAlignment="Center">
                <Frame NavigationUIVisibility="Hidden"
                       Source="View/ScanView.xaml" />
            </TabItem>
            <TabItem Header="胶水上下料"
                     Width="80"
                     Height="30"
                     Margin="2,0"
                     HorizontalAlignment="Center">
                <Frame NavigationUIVisibility="Hidden"
                       Source="View/GlueMaterialOnOffView.xaml" />
            </TabItem>

            <TabItem Header="批次号上料"
                     Width="80"
                     Height="30"
                     Margin="2,0"
                     HorizontalAlignment="Center">
                <Frame NavigationUIVisibility="Hidden"
                       Source="View/MaterialOnOffView.xaml" />
            </TabItem>
            <!--<TabItem Header="开箱设置"
                     Width="80"
                     Height="30"
                     Margin="2,0"
                     HorizontalAlignment="Center">
                <Frame NavigationUIVisibility="Hidden"
                       Source="View/MaterialOnOffView.xaml"  />
            </TabItem>-->

            <TabItem Header="NG上线"
                     Width="80"
                     Height="30"
                     Margin="2,0"
                     HorizontalAlignment="Center">
                <Frame NavigationUIVisibility="Hidden"
                       Source="View/NGOnLineView.xaml" />
            </TabItem>

            <TabItem Header="工位配置"
                     Width="80"
                     Height="30"
                     Margin="2,0"
                     HorizontalAlignment="Center">
                <Frame NavigationUIVisibility="Hidden"
                       Source="View/StationView.xaml" />
            </TabItem>

            <TabItem Header="用户录入"
                     Width="80"
                     Height="30"
                     Margin="2,0"
                     HorizontalAlignment="Center">
                <Frame NavigationUIVisibility="Hidden"
                       Source="View/UserInfoView.xaml" />
            </TabItem>
            <TabItem Header="产品型号配置"
                     Width="100"
                     Height="30"
                     Margin="2,0"
                     HorizontalAlignment="Center">
                <Frame NavigationUIVisibility="Hidden"
                       Source="View/ProductTypeView.xaml" />
            </TabItem>
        </TabControl>
        <TextBlock Text="{Binding Msg}"
                   HorizontalAlignment="Right"
                   Margin="0,0,95,0"
                   Padding="0,8"
                   Height="32"
                   VerticalAlignment="Top" />
        <Menu  VerticalAlignment="Top"
               HorizontalAlignment="Right"
               Margin="1">
            <MenuItem Header="登录"
                      Padding="31,0"
                      Height="30">
                <MenuItem Header=""
                          Height="30"
                          Margin="0">
                    <MenuItem.Template>
                        <ControlTemplate>
                            <Button Content="登录"
                                    Command="{Binding LoginCommand}"
                                    Height="30"
                                    Width="80" />
                        </ControlTemplate>
                    </MenuItem.Template>
                </MenuItem>
                <MenuItem Header=""
                          Height="30"
                          Margin="0">
                    <MenuItem.Template>
                        <ControlTemplate>
                            <Button Content="退出"
                                    Command="{Binding QuitCommand}"
                                    Height="30"
                                    Width="80" />
                        </ControlTemplate>
                    </MenuItem.Template>
                </MenuItem>
            </MenuItem>
        </Menu>
        <Button Content="登录"
                Visibility="Collapsed"
                Command="{Binding LoginCommand}"
                Height="30"
                Width="90"
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Margin="1" />
    </Grid>

</Window>
